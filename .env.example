# ============================================================
# PENFIX SHOP — Environment Variables
# Copy to .env.local and fill in real values (never commit .env.local)
# ============================================================

# --- Supabase (client-safe, exposed to browser) ---
# Shop shares its Supabase project with penfixads-OS (same job_orders/clients
# tables) — use whichever project penfixads-OS is pointed at for this environment.
# From: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase (SERVER ONLY — never expose, no NEXT_PUBLIC_ prefix) ---
# service_role key. Keep secret. Used by lib/supabase-admin.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- penfixads-OS (the ops app) ---
# The client rewards QR deep-links here so staff scanning it lands straight on a
# pre-filled New JO instead of a dead client_id string.
#   Local:   http://localhost:3003
#   Staging: the penfixads-OS staging Preview URL
#   Prod:    https://jobs.penfixads.com
NEXT_PUBLIC_JOBS_URL=http://localhost:3003

# ------------------------------------------------------------
# In Vercel, set these per environment:
#   - Production  -> production Supabase project keys + NEXT_PUBLIC_JOBS_URL=https://jobs.penfixads.com
#   - Preview     -> STAGING Supabase project keys (same one penfixads-OS staging uses)
#                    + NEXT_PUBLIC_JOBS_URL=<penfixads-OS staging Preview URL>
# See docs/STAGING.md for the full setup.
# ------------------------------------------------------------
